@model LearnBridge_E_LearningPlatform.Models.Course

<h2>Create Course</h2>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
<textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label asp-for="Level"></label>
        <select asp-for="Level" class="form-control">
            <option>Beginner</option>
            <option>Intermediate</option>
            <option>Advanced</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="TeacherId"></label>
        <select asp-for="TeacherId"
                asp-items="@(new SelectList(ViewBag.Teachers, "TeacherId", "TeacherName"))"
                class="form-control">
        </select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>

</form>