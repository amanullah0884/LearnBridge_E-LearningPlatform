@model LearnBridge_E_LearningPlatform.Models.Lesson

@{
    ViewData["Title"] = "Delete Lesson";
}

<h2 class="text-center mb-4 text-danger">Delete Lesson</h2>

<div class="alert alert-warning">
    <h5>Are you sure you want to delete this lesson?</h5>
</div>

<div class="mb-3">
    <label class="form-label">Title:</label>
    <p>@Model.Title</p>
</div>

<div class="mb-3">
    <label class="form-label">Content:</label>
    <p>@Model.Content</p>
</div>

<div class="mb-3">
    <label class="form-label">Course:</label>
    <p>@Model.Course?.Title</p>
</div>

<div class="mb-3">
    <label class="form-label">Video:</label>
    @if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        <a href="@Model.VideoUrl" target="_blank">Watch Video</a>
    }
    else
    {
        <span>No Video</span>
    }
</div>

<div class="mb-3">
    <label class="form-label">Material:</label>
    @if (!string.IsNullOrEmpty(Model.MaterialFile))
    {
        <a href="~/materials/@Model.MaterialFile" target="_blank">Download</a>
    }
    else
    {
        <span>No Material</span>
    }
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="LessonId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
