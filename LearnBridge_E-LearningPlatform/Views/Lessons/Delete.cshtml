@model LearnBridge_E_LearningPlatform.Models.Lesson

<h2>Delete Lesson</h2>

<h4>Are you sure you want to delete this lesson?</h4>

<div>

    <p><b>Title:</b> @Model.Title</p>

    <p><b>Content:</b> @Model.Content</p>

    <p><b>Course:</b> @Model.Course?.Title</p>

</div>

<form asp-action="Delete" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="LessonId" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>