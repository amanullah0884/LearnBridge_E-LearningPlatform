@model LearnBridge_E_LearningPlatform.Models.Lesson

<h2>Create Lesson</h2>

<form asp-action="Create" enctype="multipart/form-data">

    <div class="form-group">
        <label>Lesson Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Content</label>
        <textarea asp-for="Content" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Video URL</label>
        <input asp-for="VideoUrl" class="form-control" />
    </div>

    <div class="form-group">
        <label>Upload Material</label>
        <input type="file" name="MaterialUpload" class="form-control" />
    </div>

    <div class="form-group">
        <label>Course</label>
        <select asp-for="CourseId"
                asp-items="ViewBag.Courses"
                class="form-control">
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Create Lesson
    </button>

</form>